{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetCrico",
  "version": "0.1.0",
  "identifier": "com.localcinema.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NetCrico",
        "width": 1400,
        "height": 920,
        "resizable": true,
        "fullscreen": true,
        "visible": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
